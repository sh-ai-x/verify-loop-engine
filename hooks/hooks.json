{
  "PostToolUse": [
    {
      "matcher": "Edit|Write|MultiEdit",
      "hooks": [
        {
          "type": "command",
          "command": "bash",
          "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/slop-detector.sh"],
          "timeout": 5
        }
      ]
    }
  ],
  "Stop": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "bash",
          "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/verify-gate.sh"],
          "timeout": 5
        }
      ]
    }
  ]
}